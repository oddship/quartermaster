{
  "name": "quartermaster",
  "version": "0.1.0",
  "description": "Scheduled agent framework for repository maintenance - dependency updates, security audits, and more",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "quartermaster": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "files": [
    "dist",
    "templates",
    "skills"
  ],
  "keywords": [
    "ai",
    "dependency-updates",
    "automation",
    "agent",
    "maintenance",
    "quartermaster"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oddship/quartermaster"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "@mariozechner/pi-ai": "^0.55.1",
    "@mariozechner/pi-coding-agent": "^0.55.1",
    "chalk": "^5.4.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
