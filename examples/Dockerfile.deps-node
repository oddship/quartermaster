# Example: Quartermaster with Node.js toolchain for dependency updates.
# The base image already has bun, so this adds npm/node for npm-based repos.

FROM ghcr.io/oddship/quartermaster:latest

USER root

RUN apt-get update && \
    apt-get install -y --no-install-recommends nodejs npm && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

USER bun
